#!/bin/sh

# PROVIDE: openclaw
# REQUIRE: LOGIN
# KEYWORD: shutdown

# /etc/rc.conf examples
# openclaw_profiles="agent-user1 agent-user2"
# openclaw_enable="YES"
#
# openclaw_nagato_enable="YES"
# openclaw_nagato_owner="agent-user1"
# openclaw_nagato_args="gateway --port 18789"
#
# openclaw_lemarin_enable="YES"
# openclaw_lemarin_owner="agent-user2"
# openclaw_lemarin_args="gateway --port 18790"

. /etc/rc.subr

name="openclaw"
rcvar="openclaw_enable"

load_rc_config "$name"

# プロファイルが指定された場合
if [ -n "$2" ]; then
    profile="$2"
    case " ${openclaw_profiles} " in
        *" ${profile} "*)
            name="${name}_${profile}"
            load_rc_config "$name"   # ← ここが重要！再読み込み
            ;;
        *)
            echo "Error: unknown profile '$profile'" >&2
            exit 1
            ;;
    esac
# プロファイル指定なし & プロファイル定義あり → 全操作
elif [ -n "${openclaw_profiles}" ]; then
    for profile in ${openclaw_profiles}; do
        /usr/local/etc/rc.d/openclaw "$1" "${profile}"
    done
    exit 0
fi


# デフォルト設定
: ${openclaw_enable:="NO"}
: ${openclaw_owner:="www"}
: ${openclaw_home:="/home/${openclaw_owner}"}
: ${openclaw_args:="gateway --port 18789"}

# 各プロファイル固有の設定（未定義ならデフォルトを継承）
eval openclaw_owner="\${${name}_owner:-${openclaw_owner}}"
eval openclaw_args="\${${name}_args:-${openclaw_args}}"
eval openclaw_home="\${${name}_home:-/home/${openclaw_owner}}"

# キャッシュディレクトリとPID
openclaw_cache_dir="${openclaw_home}/.cache/openclaw"
pidfile="${openclaw_cache_dir}/openclaw.pid"
child_pidfile="${openclaw_cache_dir}/openclaw_proc.pid"

# 起動前にディレクトリを作成
start_precmd="openclaw_precmd"
openclaw_precmd() {
    install -d -o ${openclaw_owner} -m 700 ${openclaw_cache_dir}
}

command="/usr/sbin/daemon"
command_args="-S -T openclaw -P ${pidfile} -p ${child_pidfile} -u ${openclaw_owner} /usr/local/bin/openclaw ${openclaw_args}"

run_rc_command "$1"
